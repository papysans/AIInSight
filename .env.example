# 小红书 MCP (ShunL12324/xhs-mcp sidecar)
XHS_MCP_URL=http://xhs-mcp:18060/mcp
XHS_LOGIN_QRCODE_TIMEOUT_SECONDS=60

# XHS MCP sidecar 配置
XHS_MCP_PORT=18060
XHS_MCP_HEADLESS=true
XHS_MCP_REQUEST_INTERVAL=2000
XHS_MCP_LOG_LEVEL=info
# XHS_MCP_DATA_DIR=/data  # Docker 内部路径，一般不需要修改

# 说明：
# 1. 无需配置 LLM API Key，所有推理在宿主端 LLM 完成
# 2. CARD_PREVIEW_PUBLIC_BASE_URL 用于覆盖卡片预览图片的对外访问前缀；本地可与 PUBLIC_API_BASE_URL 保持一致
# 3. XHS_LOGIN_QRCODE_PUBLIC_BASE_URL 用于覆盖二维码图片的对外访问前缀；本地可与 PUBLIC_API_BASE_URL 保持一致
# 4. XHS_LOGIN_QRCODE_TIMEOUT_SECONDS 控制获取二维码时等待上游 xhs-mcp 的超时时间
# 5. Apple Silicon 如需从上游源码构建可用的原生镜像，可运行 ./scripts/build-xhs-mcp-image.sh
# 6. 配置完成后，将本文件重命名为 .env

# ============================================================
# 云端部署配置（本地开发可忽略以下内容）
# ============================================================
# OPINION_REQUIRE_API_KEY=true        # 开启后所有 MCP 请求必须带 X-API-Key
# OPINION_ADMIN_TOKEN=your-secret     # Admin API (/admin/api-keys) 访问令牌
# OPINION_DOMAIN=mcp.example.com      # 域名（Caddy 自动申请 HTTPS 证书）
