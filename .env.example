# LLM API Keys (多个 Key 用逗号分隔)
# Moonshot (月之暗面 Kimi)
MOONSHOT_API_KEYS=your_moonshot_key_here

# Deepseek (深度求索)
DEEPSEEK_API_KEYS=your_deepseek_key_here

# Doubao (字节豆包)
DOUBAO_API_KEYS=your_doubao_key_here

# Zhipu AI (智谱清言)
ZHIPU_API_KEYS=your_zhipu_key_here

# Gemini (Google)
GEMINI_API_KEYS=your_gemini_key1,your_gemini_key2

# 火山引擎（用于文生图服务）
VOLC_ACCESS_KEY=your_volc_access_key
VOLC_SECRET_KEY=your_volc_secret_key

# 小红书 MCP（宿主机侧服务）
XHS_MCP_URL=http://host.docker.internal:18060/mcp
PUBLIC_API_BASE_URL=http://localhost:8000
CARD_PREVIEW_PUBLIC_BASE_URL=http://localhost:8000
XHS_LOGIN_QRCODE_PUBLIC_BASE_URL=http://localhost:8000
XHS_LOGIN_QRCODE_TIMEOUT_SECONDS=30

# 可选：sidecar 模式（docker-compose.xhs.yml）
XHS_MCP_PORT=18060
XHS_MCP_IMAGE=xpzouying/xiaohongshu-mcp
XHS_MCP_PLATFORM=linux/amd64
# XHS_PROXY=http://user:pass@proxy:port

# 说明：
# 1. 所有 API Keys 都是可选的，至少配置一个厂商的 Key 即可使用
# 2. 多个 Key 用英文逗号分隔，系统会自动轮询使用
# 3. VOLC 配置用于图片生成功能，如不需要可不配置
# 4. CARD_PREVIEW_PUBLIC_BASE_URL 用于覆盖卡片预览图片的对外访问前缀；本地可与 PUBLIC_API_BASE_URL 保持一致
# 5. XHS_LOGIN_QRCODE_PUBLIC_BASE_URL 用于覆盖二维码图片的对外访问前缀；本地可与 PUBLIC_API_BASE_URL 保持一致
# 6. XHS_LOGIN_QRCODE_TIMEOUT_SECONDS 控制获取二维码时等待上游 xhs-mcp 的超时时间
# 7. 配置完成后，将本文件重命名为 .env
